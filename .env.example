# Environment Configuration for Async Data Pipeline
# Copy this file to .env and update the values as needed

# Database Configuration
DATABASE_URL=postgresql+asyncpg://pipeline_user:pipeline_pass@localhost:5432/async_pipeline

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# Application Configuration
LOG_LEVEL=INFO
DEBUG=True

# TODO: Add more environment variables
# Security Configuration
# SECRET_KEY=your-secret-key-here
# ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=30

# File Upload Configuration
# MAX_FILE_SIZE=100MB
# UPLOAD_DIRECTORY=./uploads
# ALLOWED_FILE_TYPES=csv,json,xlsx

# Worker Configuration
# WORKER_CONCURRENCY=4
# WORKER_TIMEOUT=300
# QUEUE_NAME=file-processor

# Monitoring Configuration
# SENTRY_DSN=your-sentry-dsn
# PROMETHEUS_METRICS=True
# HEALTH_CHECK_INTERVAL=30

# External Services
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password

# Development Configuration
# RELOAD=True
# DEBUG_SQL=False
# LOG_SQL_QUERIES=False